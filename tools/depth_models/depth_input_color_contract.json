    "model_input_pipeline": [
      "validate-finite-float16-scrgb",
      "float32-bilinear-sample",
      "clamp-negative-rgb",
      "luminance-reinhard",
      "uniform-peak-normalize",
      "saturate",
      "srgb-oetf",
      "imagenet-normalize",
      "nchw"
    ],
    "input_channels": {
      "accepted": ["rgb", "rgba"],
      "alpha": "ignored"
    }
  }
