    "negative_disparity_pct": {"role": "hard", "axis": "comfort", "better": "lower", "rel_tol": 0.0, "abs_floor": 0.1, "hard_max": 3.0, "trigger": 3.0, "evidence": "exact_hlsl_full_binocular_disparity"},
